NODE_ENV=development
PORT=3000

# Public URLs
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:3000

# Postgres
DATABASE_URL=postgresql://iam_user:iam_pass@localhost:5432/iam?schema=public

# Cookies
COOKIE_DOMAIN=
# If you're running locally over plain http://, set this to false so the browser accepts cookies.
# In production (HTTPS) this should be true.
COOKIE_SECURE=false
SESSION_COOKIE_NAME=__Host-iam_session
SESSION_TTL_SECONDS=28800

# 32 bytes (base64) key for AES-256-GCM encryption at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENC_KEY_B64=REPLACE_ME

# Azure AD (OIDC)
AZUREAD_TENANT_ID=REPLACE_ME
AZUREAD_CLIENT_ID=REPLACE_ME
AZUREAD_CLIENT_SECRET=REPLACE_ME
AZUREAD_REDIRECT_URI=http://localhost:3000/auth/callback
AZUREAD_SCOPES=openid profile email offline_access

# Optional Zoho
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=
ZOHO_SCOPES=openid profile email offline_access

# Feature toggles
ENABLE_SWAGGER=false

